# ============================================================
# ENVIRONMENT SELECTOR
# Options: "prod" | "local"
# ============================================================
VITE_APP_ENV=local

# ============================================================
# GRAPHQL ENDPOINT
# ============================================================
VITE_GRAPHQL_URL_LOCAL=
VITE_GRAPHQL_URL_PROD=

# ============================================================
# TSB CONTRACTS
# ============================================================
VITE_TSB_CONTRACT_BASE=
VITE_TSB_CONTRACT_ARBITRUM=
VITE_TSB_CONTRACT_LISK=
VITE_TSB_CONTRACT_MANTA=

VITE_BASE_TOKEN_URL=https://basescan.org/token/
VITE_ARBITRUM_TOKEN_URL=https://arbiscan.io/token/
VITE_LISK_TOKEN_URL=https://blockscout.lisk.com/token/
VITE_MANTA_TOKEN_URL=https://pacific-explorer.manta.network/token/

# ============================================================
# RPC URLS — used for on-chain reads (e.g. maxSupply)
# Defaults: public Base endpoints. Override with a private RPC for higher rate limits.
# ============================================================
VITE_TESTNET_RPC_URL_BASE=https://sepolia.base.org
VITE_MAINNET_RPC_URL_BASE=https://mainnet.base.org

# ============================================================
# CHAIN IDs — TESTNET
# Base Sepolia: 84532 | Arbitrum Sepolia: 421614
# Lisk Sepolia: 4202  | Manta Sepolia: 3441006
# ============================================================
VITE_TESTNET_CHAIN_ID_BASE=84532
VITE_TESTNET_CHAIN_ID_ARBITRUM=421614
VITE_TESTNET_CHAIN_ID_LISK=4202
VITE_TESTNET_CHAIN_ID_MANTA=3441006

# ============================================================
# CHAIN IDs — MAINNET
# Base: 8453 | Arbitrum One: 42161 | Lisk: 1135 | Manta: 169
# ============================================================
VITE_MAINNET_CHAIN_ID_BASE=8453
VITE_MAINNET_CHAIN_ID_ARBITRUM=42161
VITE_MAINNET_CHAIN_ID_LISK=1135
VITE_MAINNET_CHAIN_ID_MANTA=169

